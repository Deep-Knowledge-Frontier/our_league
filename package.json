{
  "name": "football-web",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/x-date-pickers": "^9.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.20",
    "firebase": "^12.11.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "react-router-dom": "^7.14.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "emulator": "firebase emulators:start --only auth,database",
    "emulator:export": "firebase emulators:start --only auth,database --import=./.emulator-data --export-on-exit=./.emulator-data",
    "seed": "node scripts/seed-emulator.js",
    "sync-prod": "node scripts/sync-from-prod.js",
    "deploy": "npm run build && firebase deploy --only hosting:uri-league",
    "backup-db": "firebase database:get // --project football-92492 --output \"backups/prod-snapshot-$(date +%Y%m%d-%H%M%S).json\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
