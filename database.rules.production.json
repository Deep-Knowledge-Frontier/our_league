{
  "rules": {
    ".read": false,
    ".write": false,

    "Users": {
      ".read": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())",

      "$emailKey": {
        ".read": "auth != null && $emailKey == auth.token.email.replace('.', ',')",
        ".write": "auth != null && ($emailKey == auth.token.email.replace('.', ',') || root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())"
      }
    },

    "AllowedUsers": {
      ".read": "auth != null",
      "admin": {
        ".write": "auth != null && root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists()"
      },
      "moderator": {
        ".write": "auth != null && root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists()"
      }
    },

    "MasterUsers": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('MasterUsers/' + auth.token.email.replace('.', ',')).exists()"
    },

    "clubs": {
      ".read": "auth != null",
      "$clubName": {
        ".write": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())"
      }
    },

    "DeletedClubs": {
      ".read": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('MasterUsers/' + auth.token.email.replace('.', ',')).exists())",
      ".write": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('MasterUsers/' + auth.token.email.replace('.', ',')).exists())"
    },

    "ClubRequests": {
      ".read": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())",

      "$requestKey": {
        ".write": "auth != null && (!data.exists() || root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())"
      }
    },

    "JoinRequests": {
      ".read": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())",
      "$clubName": {
        "$emailKey": {
          ".read": "auth != null && $emailKey == auth.token.email.replace('.', ',')",
          ".write": "auth != null && ($emailKey == auth.token.email.replace('.', ',') || root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())"
        }
      }
    },

    "LocationPresets": {
      ".read": "auth != null",
      "$clubName": {
        ".write": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())"
      }
    },

    "registeredPlayers": {
      ".read": "auth != null",
      "$clubName": {
        ".write": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())"
      }
    },

    "MatchDates": {
      ".read": "auth != null",
      "$clubName": {
        ".write": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())"
      }
    },

    "MatchTimer": {
      ".read": "auth != null",
      "$clubName": {
        ".write": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())"
      }
    },

    "PlayerSelectionByDate": {
      ".read": "auth != null",
      "$clubName": {
        "$date": {
          // 🆕 회원: 자기 투표(AttandPlayer/all, AbsentPlayer/all, UndecidedPlayer/all)와
          //          본인 시간/용병(AttendTime/{my}, Guests/{my})만 쓰기 가능
          // 🆕 운영자(admin/moderator): 모든 자식 path 쓰기 가능 (게임 로스터, 주장, 포메이션 등)

          "AttandPlayer": {
            "all":  { ".write": "auth != null" },
            "A":    { ".write": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())" },
            "B":    { ".write": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())" },
            "C":    { ".write": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())" }
          },
          "AbsentPlayer": {
            "all":  { ".write": "auth != null" }
          },
          "UndecidedPlayer": {
            "all":  { ".write": "auth != null" }
          },
          "AttendTime": {
            "$emailKey": {
              ".write": "auth != null && ($emailKey === auth.token.email.replace('.', ',') || root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())"
            }
          },
          "Guests": {
            "$emailKey": {
              ".write": "auth != null && ($emailKey === auth.token.email.replace('.', ',') || root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())"
            }
          },

          // 운영자 전용 영역 — game1/2/.../TeamCaptains/MatchOrder/FormationOpen/Draft/Formation/keyPop 등 위에 명시되지 않은 모든 자식
          "$adminOnly": {
            ".write": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())"
          }
        }
      }
    },

    "PlayerSelectionByDateBackup": {
      ".read": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())",
      ".write": "auth != null && (root.child('AllowedUsers/admin/' + auth.token.email.replace('.', ',')).exists() || root.child('AllowedUsers/moderator/' + auth.token.email.replace('.', ',')).exists())"
